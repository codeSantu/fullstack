{
  "name": "fullstack-ddd-boilerplate",
  "private": true,
  "packageManager": "npm@11.11.1",
  "workspaces": [
    "apps/*",
    "packages/*",
    "infrastructure"
  ],
  "overrides": {
    "next": "16.1.6",
    "@netlify/plugin-nextjs": "5.15.9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "netlify-cli": "^24.2.0",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3"
  }
}
