{
    "$schema": "https://turbo.build/schema.json",
    "globalPassThroughEnv": [
        "TURSO_DB_URL",
        "TURSO_TOKEN",
        "AWS_REGION",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_S3_BUCKET",
        "REDIS_HOST",
        "NEXT_PUBLIC_API_BASE_URL",
        "NEXT_PUBLIC_SOCKET_URL",
        "CRASH_ME_STRICTLY"
    ],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build",
                "db:generate"
            ],
            "outputs": [
                "dist/**",
                ".next/**",
                "!.next/cache/**"
            ]
        },
        "db:generate": {
            "cache": true,
            "inputs": [
                "prisma/schema.prisma"
            ],
            "outputs": [
                "node_modules/.prisma/**"
            ]
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ]
        },
        "check": {
            "dependsOn": [
                "lint",
                "test",
                "build"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "test": {
            "dependsOn": [
                "build"
            ],
            "outputs": [
                "coverage/**"
            ]
        },
        "test:e2e": {
            "dependsOn": [
                "build"
            ],
            "outputs": [
                "playwright-report/**",
                "test-results/**"
            ]
        }
    }
}